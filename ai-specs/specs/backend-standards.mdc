│           └── RegistrationsEndpointsTests.cs
├── Integration/
│   └── Features/
│       ├── CampsIntegrationTests.cs
│       └── RegistrationsIntegrationTests.cs
└── Helpers/
    ├── Builders/
    │   └── CampBuilder.cs
    └── Fixtures/
        └── WebAppFixture.cs
```

### Test Naming Convention

Use the pattern: `MethodName_StateUnderTest_ExpectedBehavior`

```csharp
public class CampsServiceTests
{
    [Fact]
    public async Task GetByIdAsync_WhenCampExists_ReturnsCampResponse()
    {
        // ...
    }

    [Fact]
    public async Task GetByIdAsync_WhenCampDoesNotExist_ReturnsNull()
    {
        // ...
    }

    [Fact]
    public async Task CreateAsync_WhenValidRequest_CreatesCampAndReturnsResponse()
    {
        // ...
    }

    [Fact]
    public async Task CreateAsync_WhenEndDateBeforeStartDate_ThrowsBusinessRuleException()
    {
        // ...
    }
}
```

### Test Structure (AAA Pattern)

Always follow the Arrange-Act-Assert pattern:

```csharp
public class CampsServiceTests
{
    private readonly ICampsRepository _repository;
    private readonly CampsService _sut;

    public CampsServiceTests()
    {
        _repository = Substitute.For<ICampsRepository>();
        _sut = new CampsService(_repository);
    }

    [Fact]
    public async Task GetByIdAsync_WhenCampExists_ReturnsCampResponse()
    {
        // Arrange
        var campId = Guid.NewGuid();
        var camp = new CampBuilder().WithId(campId).WithName("Summer Camp").Build();
        _repository.GetByIdAsync(campId, Arg.Any<CancellationToken>()).Returns(camp);

        // Act
        var result = await _sut.GetByIdAsync(campId, CancellationToken.None);

        // Assert
        result.Should().NotBeNull();
        result!.Id.Should().Be(campId);
        result.Name.Should().Be("Summer Camp");
        await _repository.Received(1).GetByIdAsync(campId, Arg.Any<CancellationToken>());
    }

    [Fact]
    public async Task GetByIdAsync_WhenCampDoesNotExist_ReturnsNull()
    {
        // Arrange
        var campId = Guid.NewGuid();
        _repository.GetByIdAsync(campId, Arg.Any<CancellationToken>()).Returns((Camp?)null);

        // Act
        var result = await _sut.GetByIdAsync(campId, CancellationToken.None);

        // Assert
        result.Should().BeNull();
    }
}
```

### Mocking with NSubstitute

- Use `Substitute.For<T>()` to create mocks for interfaces
- Use `Arg.Any<T>()` for flexible argument matching
- Use `.Returns()` for setting up return values
- Use `.Received()` for verifying method calls
- Use `.ThrowsAsync()` for simulating exceptions

```csharp
// Create a substitute
var repository = Substitute.For<ICampsRepository>();

// Setup return value
repository.GetByIdAsync(Arg.Any<Guid>(), Arg.Any<CancellationToken>())
    .Returns(new Camp { Id = Guid.NewGuid(), Name = "Test Camp" });

// Setup exception
repository.AddAsync(Arg.Any<Camp>(), Arg.Any<CancellationToken>())
    .ThrowsAsync(new DbUpdateException("Database error", (Exception?)null));

// Verify calls
await repository.Received(1).AddAsync(
    Arg.Is<Camp>(c => c.Name == "Summer Camp"),
    Arg.Any<CancellationToken>());

// Verify no calls
await repository.DidNotReceive().DeleteAsync(Arg.Any<Guid>(), Arg.Any<CancellationToken>());
```


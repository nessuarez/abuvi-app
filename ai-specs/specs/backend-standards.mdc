### Feature Slice Structure

Each feature folder contains these files:

```csharp
// Features/Camps/CampsEndpoints.cs — API endpoint definitions
public static class CampsEndpoints
{
    public static void MapCampsEndpoints(this IEndpointRouteBuilder app)
    {
        var group = app.MapGroup("/api/camps")
            .WithTags("Camps");

        group.MapGet("/", GetAllCamps);
        group.MapGet("/{id:guid}", GetCampById);
        group.MapPost("/", CreateCamp);
        group.MapPut("/{id:guid}", UpdateCamp);
        group.MapDelete("/{id:guid}", DeleteCamp);
    }
}

// Features/Camps/CampsModels.cs — Request/Response DTOs and domain entity
public record CreateCampRequest(
    string Name,
    string Location,
    DateOnly StartDate,
    DateOnly EndDate,
    int MaxParticipants,
    decimal PricePerPerson);

public record CampResponse(
    Guid Id,
    string Name,
    string Location,
    DateOnly StartDate,
    DateOnly EndDate,
    int MaxParticipants,
    decimal PricePerPerson,
    string Status);

public class Camp
{
    public Guid Id { get; set; }
    public string Name { get; set; } = string.Empty;
    public string Location { get; set; } = string.Empty;
    public DateOnly StartDate { get; set; }
    public DateOnly EndDate { get; set; }
    public int MaxParticipants { get; set; }
    public decimal PricePerPerson { get; set; }
    public CampStatus Status { get; set; } = CampStatus.Draft;
}

// Features/Camps/CampsService.cs — Business logic
public class CampsService(ICampsRepository repository)
{
    public async Task<CampResponse> CreateAsync(CreateCampRequest request, CancellationToken ct)
    {
        var camp = new Camp
        {
            Id = Guid.NewGuid(),
            Name = request.Name,
            Location = request.Location,
            StartDate = request.StartDate,
            EndDate = request.EndDate,
            MaxParticipants = request.MaxParticipants,
            PricePerPerson = request.PricePerPerson
        };

        await repository.AddAsync(camp, ct);
        return camp.ToResponse();
    }
}

// Features/Camps/CampsRepository.cs — Data access
public interface ICampsRepository
{
    Task<Camp?> GetByIdAsync(Guid id, CancellationToken ct);
    Task<IReadOnlyList<Camp>> GetAllAsync(CancellationToken ct);
    Task AddAsync(Camp camp, CancellationToken ct);
    Task UpdateAsync(Camp camp, CancellationToken ct);
    Task DeleteAsync(Guid id, CancellationToken ct);
}

public class CampsRepository(AbuviDbContext db) : ICampsRepository
{
    public async Task<Camp?> GetByIdAsync(Guid id, CancellationToken ct)
        => await db.Camps.FindAsync([id], ct);

    public async Task AddAsync(Camp camp, CancellationToken ct)
    {
        db.Camps.Add(camp);
        await db.SaveChangesAsync(ct);
    }
}
```

### Cross-Cutting Concerns

Shared code belongs in the `Common/` folder. Only extract shared code when it is used by **two or more features**. Do not create premature abstractions.

**What belongs in Common:**

- Global error-handling middleware
- Shared response models (`ApiResponse<T>`, `PagedResult<T>`)
- Validation endpoint filters
- Authentication/authorization middleware
- Extension methods for service registration

**What does NOT belong in Common:**

- Feature-specific business logic
- Feature-specific DTOs or entities
- Feature-specific validators

## SOLID and DRY Principles

### Single Responsibility Principle (SRP)

Each class should have a single responsibility or reason to change.

**Before:**

```csharp
// A single class handling validation, business logic, and data access
public class CampManager
{
    private readonly AbuviDbContext _db;

    public async Task<Camp> CreateCamp(CreateCampRequest request)
    {
        // Validation mixed with business logic
        if (string.IsNullOrEmpty(request.Name))
            throw new ArgumentException("Name is required");
        if (request.StartDate >= request.EndDate)
            throw new ArgumentException("Invalid date range");

        // Business logic mixed with data access
        var camp = new Camp { Name = request.Name, StartDate = request.StartDate };
        _db.Camps.Add(camp);
        await _db.SaveChangesAsync();

        // Notification mixed with creation
        await SendEmailNotification(camp);
        return camp;
    }
}
```

**After:**

```csharp
// Validation is handled by FluentValidation
public class CreateCampValidator : AbstractValidator<CreateCampRequest>
{
    public CreateCampValidator()
    {
        RuleFor(x => x.Name).NotEmpty().MaximumLength(200);
        RuleFor(x => x.EndDate).GreaterThan(x => x.StartDate);
    }
}

// Business logic in the service
public class CampsService(ICampsRepository repository)
{
    public async Task<CampResponse> CreateAsync(CreateCampRequest request, CancellationToken ct)
    {
        var camp = new Camp
        {
            Id = Guid.NewGuid(),
            Name = request.Name,
            StartDate = request.StartDate,
            EndDate = request.EndDate
        };

        await repository.AddAsync(camp, ct);
        return camp.ToResponse();
    }
}

// Data access in the repository
public class CampsRepository(AbuviDbContext db) : ICampsRepository
{
    public async Task AddAsync(Camp camp, CancellationToken ct)
    {
        db.Camps.Add(camp);
        await db.SaveChangesAsync(ct);
    }
}
```

**Explanation**: Each class has one reason to change — the validator handles validation rules, the service handles business logic, and the repository handles data access.

### Open/Closed Principle (OCP)

Software entities should be open for extension but closed for modification.

**Before:**

```csharp
// Adding a new payment method requires modifying the existing class
public class PaymentProcessor
{
    public async Task ProcessPayment(Payment payment)
    {
        if (payment.Method == PaymentMethod.Card)
        {
            // Process card payment via Redsys
        }
        else if (payment.Method == PaymentMethod.Transfer)
        {
            // Process bank transfer
        }
        // Adding Cash requires modifying this method
    }
}
```

**After:**

```csharp
// Define an interface for payment processing
public interface IPaymentHandler
{
    PaymentMethod Method { get; }
    Task<PaymentResult> ProcessAsync(Payment payment, CancellationToken ct);
}

// Each payment method is a separate implementation
public class CardPaymentHandler(IRedsysClient redsys) : IPaymentHandler
{
    public PaymentMethod Method => PaymentMethod.Card;

    public async Task<PaymentResult> ProcessAsync(Payment payment, CancellationToken ct)
    {
        // Process card payment via Redsys
        return await redsys.ChargeAsync(payment, ct);
    }
}

public class TransferPaymentHandler : IPaymentHandler
{
    public PaymentMethod Method => PaymentMethod.Transfer;

    public async Task<PaymentResult> ProcessAsync(Payment payment, CancellationToken ct)
    {
        // Record transfer as pending verification
        return PaymentResult.Pending("Awaiting bank transfer confirmation");
    }
}

// Processor delegates to the right handler — no modification needed for new methods
public class PaymentProcessor(IEnumerable<IPaymentHandler> handlers)
{
    public async Task<PaymentResult> ProcessAsync(Payment payment, CancellationToken ct)
    {
        var handler = handlers.FirstOrDefault(h => h.Method == payment.Method)
            ?? throw new NotSupportedException($"Payment method {payment.Method} is not supported");

        return await handler.ProcessAsync(payment, ct);
    }
}
```

**Explanation**: Adding a new payment method (e.g., Cash) only requires creating a new `IPaymentHandler` implementation and registering it in DI — without modifying existing code.

### Liskov Substitution Principle (LSP)

Objects of a derived class should be replaceable with objects of the base class without altering program correctness.

**Before:**

```csharp
// Subclass violates the base class contract
public abstract class BaseRepository<T>
{
    public abstract Task<T> GetByIdAsync(Guid id, CancellationToken ct);
    public abstract Task DeleteAsync(Guid id, CancellationToken ct);
}

public class MemoryRepository : BaseRepository<Memory>
{
    public override async Task DeleteAsync(Guid id, CancellationToken ct)
    {
        // Memories cannot be deleted, only archived — this violates LSP
        throw new NotSupportedException("Memories cannot be deleted");
    }
}
```

**After:**

```csharp
// Use separate interfaces for read and write operations
public interface IReadRepository<T>
{
    Task<T?> GetByIdAsync(Guid id, CancellationToken ct);
    Task<IReadOnlyList<T>> GetAllAsync(CancellationToken ct);
}

public interface IDeletableRepository<T> : IReadRepository<T>
{
    Task DeleteAsync(Guid id, CancellationToken ct);
}

// Memories only implement read + archive, not delete
public interface IMemoriesRepository : IReadRepository<Memory>
{
    Task AddAsync(Memory memory, CancellationToken ct);
    Task ArchiveAsync(Guid id, CancellationToken ct);
}
```

**Explanation**: By separating read and delete capabilities into different interfaces, classes only implement the operations they truly support. Code that depends on `IReadRepository<T>` works correctly with any implementation.

### Interface Segregation Principle (ISP)

Many specific interfaces are better than a single general interface.

**Before:**

```csharp
// A large interface that forces implementations to include methods they do not need
public interface ICampOperations
{
    Task<Camp> CreateAsync(CreateCampRequest request, CancellationToken ct);
    Task<Camp> UpdateAsync(Guid id, UpdateCampRequest request, CancellationToken ct);
    Task DeleteAsync(Guid id, CancellationToken ct);
    Task<PaymentResult> ProcessPaymentAsync(Payment payment, CancellationToken ct);
    Task SendNotificationAsync(Guid campId, string message, CancellationToken ct);
    Task<byte[]> GenerateReportAsync(Guid campId, CancellationToken ct);
}
```

**After:**

```csharp
// Segregated interfaces — each focused on a single concern
public interface ICampsService
{
    Task<CampResponse> CreateAsync(CreateCampRequest request, CancellationToken ct);
    Task<CampResponse> UpdateAsync(Guid id, UpdateCampRequest request, CancellationToken ct);
    Task DeleteAsync(Guid id, CancellationToken ct);
}

public interface IPaymentProcessor
{
    Task<PaymentResult> ProcessAsync(Payment payment, CancellationToken ct);
}

public interface INotificationService
{
    Task SendAsync(Guid campId, string message, CancellationToken ct);
}
```

**Explanation**: Each interface represents a single concern. Classes only implement the interfaces relevant to their responsibility, keeping implementations focused and testable.

### Dependency Inversion Principle (DIP)

High-level modules should not depend on low-level modules; both should depend on abstractions.

**Before:**

```csharp
// Service directly depends on concrete EF Core DbContext
public class CampsService
{
    private readonly AbuviDbContext _db;

    public CampsService()
    {
        _db = new AbuviDbContext(); // Direct instantiation of concrete dependency
    }

    public async Task<Camp?> GetByIdAsync(Guid id, CancellationToken ct)
    {
        return await _db.Camps.FindAsync([id], ct);
    }
}
```

**After:**

```csharp
// Service depends on an abstraction (interface)
public interface ICampsRepository
{
    Task<Camp?> GetByIdAsync(Guid id, CancellationToken ct);
    Task AddAsync(Camp camp, CancellationToken ct);
}

// Concrete implementation injected via DI
public class CampsRepository(AbuviDbContext db) : ICampsRepository
{
    public async Task<Camp?> GetByIdAsync(Guid id, CancellationToken ct)
        => await db.Camps.FindAsync([id], ct);

    public async Task AddAsync(Camp camp, CancellationToken ct)
    {
        db.Camps.Add(camp);
        await db.SaveChangesAsync(ct);
    }
}

// Service receives the abstraction through constructor injection
public class CampsService(ICampsRepository repository)
{
    public async Task<CampResponse?> GetByIdAsync(Guid id, CancellationToken ct)
    {
        var camp = await repository.GetByIdAsync(id, ct);
        return camp?.ToResponse();
    }
}

// Registration in Program.cs
builder.Services.AddScoped<ICampsRepository, CampsRepository>();
builder.Services.AddScoped<CampsService>();
```

**Explanation**: `CampsService` depends on the `ICampsRepository` interface, not the concrete `CampsRepository`. This allows swapping implementations (e.g., for testing with NSubstitute) without modifying the service.

### DRY (Don't Repeat Yourself)

Each piece of knowledge should have a single, unambiguous, and authoritative representation.

**Before:**

```csharp
// Repeated response mapping in multiple endpoints
public static async Task<IResult> GetCampById(Guid id, CampsService service, CancellationToken ct)
{
    var camp = await service.GetByIdAsync(id, ct);
    if (camp is null)
        return Results.NotFound(new { success = false, error = new { message = "Camp not found" } });
    return Results.Ok(new { success = true, data = camp });
}

public static async Task<IResult> GetRegistrationById(Guid id, RegistrationsService service, CancellationToken ct)
{
    var registration = await service.GetByIdAsync(id, ct);
    if (registration is null)
        return Results.NotFound(new { success = false, error = new { message = "Registration not found" } });
    return Results.Ok(new { success = true, data = registration });
}
```

**After:**

```csharp
// Shared response wrapper in Common/Models/
public record ApiResponse<T>(bool Success, T? Data = default, ApiError? Error = null)
{
    public static ApiResponse<T> Ok(T data) => new(true, data);
    public static ApiResponse<T> NotFound(string message) =>
        new(false, Error: new ApiError(message, "NOT_FOUND"));
    public static ApiResponse<T> Fail(string message, string code) =>
        new(false, Error: new ApiError(message, code));
}

public record ApiError(string Message, string Code);

// Endpoints use the shared wrapper
public static async Task<IResult> GetCampById(Guid id, CampsService service, CancellationToken ct)
{
    var camp = await service.GetByIdAsync(id, ct);
    return camp is not null
        ? Results.Ok(ApiResponse<CampResponse>.Ok(camp))
        : Results.NotFound(ApiResponse<CampResponse>.NotFound("Camp not found"));
}
```

**Explanation**: The response format is centralized in `ApiResponse<T>`, eliminating duplication across endpoints and ensuring consistent API responses.

## Coding Standards

### Naming Conventions

- **Classes, Methods, Properties**: PascalCase (`CampsService`, `GetByIdAsync`, `MaxParticipants`)
- **Local Variables, Parameters**: camelCase (`campId`, `cancellationToken`)
- **Constants**: PascalCase (`MaxCampsPerPage`) — following .NET conventions
- **Interfaces**: PascalCase prefixed with `I` (`ICampsRepository`, `IPaymentHandler`)
- **Enums**: PascalCase for type and members (`CampStatus.Open`)
- **File Naming**: PascalCase matching the primary type (`CampsService.cs`, `CampsEndpoints.cs`)
- **Private Fields**: camelCase with underscore prefix (`_repository`, `_logger`)

**Examples:**

```csharp
// Good: .NET naming conventions
public class CampsService(ICampsRepository repository, ILogger<CampsService> logger)
{
    public async Task<CampResponse?> GetByIdAsync(Guid campId, CancellationToken ct)
    {
        var camp = await repository.GetByIdAsync(campId, ct);
        if (camp is null)
        {
            logger.LogWarning("Camp {CampId} not found", campId);
            return null;
        }
        return camp.ToResponse();
    }
}

// Avoid: non-.NET naming conventions
public class camps_service
{
    public async Task<CampResponse?> get_by_id(Guid camp_id)
    {
        // snake_case and missing CancellationToken
    }
}
```

### C# and .NET Usage

- **Nullable Reference Types**: Always enable (`<Nullable>enable</Nullable>` in `.csproj`)
- **Primary Constructors**: Use for dependency injection (`public class CampsService(ICampsRepository repo)`)
- **Record Types**: Use for DTOs and Value Objects (`public record CreateCampRequest(...)`)
- **Pattern Matching**: Prefer over type checking and null comparison
- **File-Scoped Namespaces**: Use `namespace Abuvi.API.Features.Camps;` (not block-scoped)
- **Avoid `var` abuse**: Use `var` when the type is obvious from the right side; use explicit types otherwise
- **CancellationToken**: Always accept and pass `CancellationToken` in async methods

```csharp
// Good: Modern C# patterns
namespace Abuvi.API.Features.Camps;

public record CreateCampRequest(string Name, DateOnly StartDate, DateOnly EndDate);

public class CampsService(ICampsRepository repository)
{
    public async Task<CampResponse?> GetByIdAsync(Guid id, CancellationToken ct)
    {
        var camp = await repository.GetByIdAsync(id, ct);
        return camp switch
        {
            null => null,
            { Status: CampStatus.Draft } => throw new InvalidOperationException("Draft camps are not visible"),
            _ => camp.ToResponse()
        };
    }
}

// Avoid: Legacy C# patterns
namespace Abuvi.API.Features.Camps
{
    public class CreateCampRequest
    {
        public string Name { get; set; }  // Should be a record
        public DateTime StartDate { get; set; }  // Should be DateOnly
    }

    public class CampsService
    {
        private readonly ICampsRepository _repository;
        public CampsService(ICampsRepository repository)  // Should use primary constructor
        {
            _repository = repository;
        }
    }
}
```

### Error Handling

- **Custom Exception Classes**: Create domain-specific exceptions for expected error conditions
- **Global Error Middleware**: Use a centralized middleware for consistent error responses
- **Error Messages**: Provide descriptive messages in English
- **Do Not Catch Generic Exceptions**: Only catch specific exceptions you can handle

```csharp
// Domain-specific exceptions
public class NotFoundException(string entityName, Guid id)
    : Exception($"{entityName} with ID '{id}' was not found");

public class BusinessRuleException(string message)
    : Exception(message);

// Global error-handling middleware
public class GlobalExceptionMiddleware(RequestDelegate next, ILogger<GlobalExceptionMiddleware> logger)
{
    public async Task InvokeAsync(HttpContext context)
    {
        try
        {
            await next(context);
        }
        catch (NotFoundException ex)
        {
            logger.LogWarning(ex, "Resource not found");
            context.Response.StatusCode = StatusCodes.Status404NotFound;
            await context.Response.WriteAsJsonAsync(
                ApiResponse<object>.NotFound(ex.Message));
        }
        catch (BusinessRuleException ex)
        {
            logger.LogWarning(ex, "Business rule violation");
            context.Response.StatusCode = StatusCodes.Status422UnprocessableEntity;
            await context.Response.WriteAsJsonAsync(
                ApiResponse<object>.Fail(ex.Message, "BUSINESS_RULE_VIOLATION"));
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Unhandled exception");
            context.Response.StatusCode = StatusCodes.Status500InternalServerError;
            await context.Response.WriteAsJsonAsync(
                ApiResponse<object>.Fail("An unexpected error occurred", "INTERNAL_ERROR"));
        }
    }
}
```

### Logging Standards

- **Use ILogger\<T\>**: Use the built-in `ILogger<T>` from Microsoft.Extensions.Logging
- **Structured Logging**: Use message templates with named parameters (not string interpolation)
- **Log Levels**: Use appropriate levels — `Information` for business events, `Warning` for recoverable issues, `Error` for failures

```csharp
// Good: Structured logging with named parameters
logger.LogInformation("Camp {CampId} created by user {UserId}", camp.Id, userId);
logger.LogWarning("Registration {RegistrationId} cancelled: {Reason}", registration.Id, reason);
logger.LogError(ex, "Failed to process payment {PaymentId}", payment.Id);

// Avoid: String interpolation in log messages (defeats structured logging)
logger.LogInformation($"Camp {camp.Id} created by user {userId}");
```

## Minimal API Design Standards

### Endpoint Definitions

- **Resource-Based URLs**: URLs represent resources, not actions
- **MapGroup**: Group endpoints by feature with shared prefix
- **HTTP Methods**: Use appropriate methods (GET, POST, PUT, DELETE, PATCH)
- **WithTags**: Add OpenAPI tags for documentation grouping
- **CancellationToken**: Always accept in endpoint handlers

```csharp
public static class CampsEndpoints
{
    public static void MapCampsEndpoints(this IEndpointRouteBuilder app)
    {
        var group = app.MapGroup("/api/camps")
            .WithTags("Camps");

        group.MapGet("/", GetAllCamps)
            .WithName("GetAllCamps")
            .Produces<ApiResponse<IReadOnlyList<CampResponse>>>();

        group.MapGet("/{id:guid}", GetCampById)
            .WithName("GetCampById")
            .Produces<ApiResponse<CampResponse>>()
            .Produces(StatusCodes.Status404NotFound);

        group.MapPost("/", CreateCamp)
            .WithName("CreateCamp")
            .Produces<ApiResponse<CampResponse>>(StatusCodes.Status201Created)
            .Produces(StatusCodes.Status400BadRequest);

        group.MapPut("/{id:guid}", UpdateCamp)
            .WithName("UpdateCamp");

        group.MapDelete("/{id:guid}", DeleteCamp)
            .WithName("DeleteCamp")
            .Produces(StatusCodes.Status204NoContent);
    }

    private static async Task<IResult> GetCampById(
        Guid id,
        CampsService service,
        CancellationToken ct)
    {
        var camp = await service.GetByIdAsync(id, ct);
        return camp is not null
            ? Results.Ok(ApiResponse<CampResponse>.Ok(camp))
            : Results.NotFound(ApiResponse<CampResponse>.NotFound("Camp not found"));
    }

    private static async Task<IResult> CreateCamp(
        CreateCampRequest request,
        CampsService service,
        CancellationToken ct)
    {
        var camp = await service.CreateAsync(request, ct);
        return Results.Created($"/api/camps/{camp.Id}", ApiResponse<CampResponse>.Ok(camp));
    }
}

// Register in Program.cs
app.MapCampsEndpoints();
app.MapRegistrationsEndpoints();
```

### Request and Response Patterns

- **JSON Format**: Use JSON for all request and response bodies
- **Consistent Structure**: All responses wrapped in `ApiResponse<T>`
- **Use Records**: DTOs should be immutable `record` types

```csharp

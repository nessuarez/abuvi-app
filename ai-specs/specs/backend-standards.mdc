## Validation Patterns

### FluentValidation Setup

Define one validator per request DTO. Place validators in the same feature folder.

```csharp
// Features/Camps/CreateCampValidator.cs
public class CreateCampValidator : AbstractValidator<CreateCampRequest>
{
    public CreateCampValidator()
    {
        RuleFor(x => x.Name)
            .NotEmpty()
            .MaximumLength(200);

        RuleFor(x => x.StartDate)
            .GreaterThan(DateOnly.FromDateTime(DateTime.UtcNow))
            .WithMessage("Start date must be in the future");

        RuleFor(x => x.EndDate)
            .GreaterThan(x => x.StartDate)
            .WithMessage("End date must be after start date");

        RuleFor(x => x.MaxParticipants)
            .InclusiveBetween(1, 500);

        RuleFor(x => x.PricePerPerson)
            .GreaterThanOrEqualTo(0)
            .PrecisionScale(10, 2, ignoreTrailingZeros: true);
    }
}
```

### Validation Pipeline

Register FluentValidation and create an endpoint filter for automatic validation:

```csharp
// Program.cs — register validators
builder.Services.AddValidatorsFromAssemblyContaining<Program>();

// Common/Filters/ValidationFilter.cs
public class ValidationFilter<T> : IEndpointFilter where T : class
{
    public async ValueTask<object?> InvokeAsync(
        EndpointFilterInvocationContext context,
        EndpointFilterDelegate next)
    {
        var validator = context.HttpContext.RequestServices.GetService<IValidator<T>>();
        if (validator is null)
            return await next(context);

        var request = context.Arguments.OfType<T>().FirstOrDefault();
        if (request is null)
            return await next(context);

        var result = await validator.ValidateAsync(request);
        if (!result.IsValid)
        {
            var errors = result.Errors.Select(e => new { field = e.PropertyName, message = e.ErrorMessage });
            return Results.BadRequest(ApiResponse<object>.Fail("Validation failed", "VALIDATION_ERROR"));
        }

        return await next(context);
    }
}

// Usage in endpoint registration
group.MapPost("/", CreateCamp)
    .AddEndpointFilter<ValidationFilter<CreateCampRequest>>();
```


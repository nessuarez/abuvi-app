### Maps Integration

Use Leaflet.js for the interactive historical camp locations map:

```vue
<script setup lang="ts">
import { onMounted, ref } from 'vue'
import L from 'leaflet'
import type { CampLocation } from '@/types/camp'

const props = defineProps<{ locations: CampLocation[] }>()
const mapContainer = ref<HTMLElement | null>(null)

onMounted(() => {
  if (!mapContainer.value) return

  const map = L.map(mapContainer.value).setView([40.4168, -3.7038], 6)

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap contributors'
  }).addTo(map)

  props.locations.forEach((location) => {
    L.marker([location.latitude, location.longitude])
      .addTo(map)
      .bindPopup(`<strong>${location.name}</strong><br>${location.year}`)
  })
})
</script>

<template>
  <div ref="mapContainer" class="h-96 w-full rounded-lg" />
</template>
```

## Testing Standards

### Unit Testing with Vitest

- Use Vitest for unit tests (composables, utilities, stores)
- Follow the **AAA pattern** (Arrange-Act-Assert)
- Use **descriptive test names**: `should [expected behavior] when [condition]`

```typescript
// composables/__tests__/useCamps.test.ts
import { describe, it, expect, vi, beforeEach } from 'vitest'
import { useCamps } from '@/composables/useCamps'
import { api } from '@/utils/api'

vi.mock('@/utils/api')

describe('useCamps', () => {
  beforeEach(() => {
    vi.clearAllMocks()
  })

  it('should fetch camps successfully', async () => {
    // Arrange
    const mockCamps = [
      { id: '1', name: 'Summer Camp', status: 'Open' },
      { id: '2', name: 'Winter Camp', status: 'Draft' }
    ]
    vi.mocked(api.get).mockResolvedValue({
      data: { success: true, data: mockCamps, error: null }
    })

    // Act
    const { camps, loading, error, fetchCamps } = useCamps()
    await fetchCamps()

    // Assert
    expect(camps.value).toEqual(mockCamps)
    expect(loading.value).toBe(false)
    expect(error.value).toBeNull()
    expect(api.get).toHaveBeenCalledWith('/camps')
  })

  it('should set error when fetch fails', async () => {
    // Arrange
    vi.mocked(api.get).mockRejectedValue(new Error('Network error'))

    // Act
    const { camps, error, fetchCamps } = useCamps()
    await fetchCamps()

    // Assert
    expect(camps.value).toEqual([])
    expect(error.value).toBe('Failed to load camps')
  })
})
```


### Form Handling

- Use **PrimeVue form components** (InputText, Select, DatePicker, etc.)
- Implement **real-time validation** where appropriate
- **Disable submit buttons** during submission
- Use **multi-step wizards** for complex registration flows

**Before (Plain HTML form):**

```vue
<template>
  <form @submit.prevent="handleSubmit">
    <label>Name</label>
    <input v-model="formData.name" type="text" required />
    <label>Date</label>
    <input v-model="formData.date" type="date" />
    <button type="submit">Save</button>
  </form>
</template>
```

**After (PrimeVue form with validation):**

```vue
<script setup lang="ts">
import { reactive, ref } from 'vue'
import InputText from 'primevue/inputtext'
import DatePicker from 'primevue/datepicker'
import Button from 'primevue/button'
import Message from 'primevue/message'

const formData = reactive({
  name: '',
  startDate: null as Date | null,
  endDate: null as Date | null
})

const errors = ref<Record<string, string>>({})
const submitting = ref(false)

const validate = (): boolean => {
  errors.value = {}
  if (!formData.name.trim()) {
    errors.value.name = 'Name is required'
  }
  if (!formData.startDate) {
    errors.value.startDate = 'Start date is required'
  }
  if (formData.startDate && formData.endDate && formData.endDate <= formData.startDate) {
    errors.value.endDate = 'End date must be after start date'
  }
  return Object.keys(errors.value).length === 0
}

const handleSubmit = async () => {
  if (!validate()) return
  submitting.value = true
  try {
    // API call via composable
  } finally {
    submitting.value = false
  }
}
</script>

<template>
  <form class="flex max-w-md flex-col gap-4" @submit.prevent="handleSubmit">
    <div>
      <label for="name" class="mb-1 block text-sm font-medium">Camp Name *</label>
      <InputText id="name" v-model="formData.name" class="w-full" :invalid="!!errors.name" />
      <small v-if="errors.name" class="text-red-500">{{ errors.name }}</small>
    </div>

    <div>
      <label for="startDate" class="mb-1 block text-sm font-medium">Start Date *</label>
      <DatePicker id="startDate" v-model="formData.startDate" date-format="dd/mm/yy" class="w-full" />
      <small v-if="errors.startDate" class="text-red-500">{{ errors.startDate }}</small>
    </div>

    <Button type="submit" label="Create Camp" :loading="submitting" :disabled="submitting" />
  </form>
</template>
```

### Navigation Patterns

- Use **Vue Router** for all navigation
- Implement **route guards** for protected pages
- Use **programmatic navigation** with `useRouter`

```typescript
// router/index.ts
import { createRouter, createWebHistory } from 'vue-router'
import { useAuthStore } from '@/stores/auth'

const router = createRouter({
  history: createWebHistory(),
  routes: [
    { path: '/', component: () => import('@/pages/HomePage.vue') },
    { path: '/camps', component: () => import('@/pages/CampsPage.vue') },
    { path: '/camps/:id', component: () => import('@/pages/CampDetailPage.vue') },
    {
      path: '/register/:campId',
      component: () => import('@/pages/RegistrationPage.vue'),
      meta: { requiresAuth: true }
    },
    {
      path: '/admin',
      component: () => import('@/pages/admin/AdminDashboard.vue'),
      meta: { requiresAuth: true, requiresAdmin: true }
    },
    { path: '/memories', component: () => import('@/pages/MemoriesPage.vue') },
    { path: '/gallery', component: () => import('@/pages/PhotoGalleryPage.vue') }
  ]
})

// Route guard for authentication
router.beforeEach((to) => {
  const auth = useAuthStore()

  if (to.meta.requiresAuth && !auth.isAuthenticated) {
    return { path: '/login', query: { redirect: to.fullPath } }
  }

  if (to.meta.requiresAdmin && !auth.isAdmin) {
    return { path: '/' }
  }
})

export default router
```

